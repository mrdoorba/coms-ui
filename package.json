  "description": "COMS UI components — chrome shells (ServiceBar, Sidebar, MobileTopBar, MobileBottomNav) + shadcn-style primitives (Button, Card, Dialog, DropdownMenu, Select, Sheet, Tabs, Avatar, Badge, Input, Label, Table, Textarea, Separator, Skeleton). Compositions reserved for a future shared candidate.",
  "type": "module",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
