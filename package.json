  },
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./primitives": "./src/primitives/index.ts",
    "./chrome": "./src/chrome/index.ts",
    "./compositions": "./src/compositions/index.ts",
    "./styles.css": "./src/styles.css"
  },
  "files": [
    "src",
    "README.md"
  ],
  "scripts": {
